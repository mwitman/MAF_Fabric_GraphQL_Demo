# -----------------------------------------------------------
# Stage 1: Build the React frontend
# -----------------------------------------------------------
FROM node:20-alpine AS frontend-build

WORKDIR /app/frontend
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install
COPY frontend/ ./
RUN npm run build
# Output lands in /app/frontend/../backend/static (= /app/backend/static)

# -----------------------------------------------------------
# Stage 2: Python runtime
# -----------------------------------------------------------
FROM python:3.12-slim AS runtime

# Prevent .pyc files and enable unbuffered output
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Install Python deps from frozen lockfile (--no-deps bypasses openai version
# conflict in agent-framework-core metadata — the pinned set is tested working)
COPY backend/requirements-frozen.txt ./requirements-frozen.txt
RUN pip install --no-cache-dir --no-deps -r requirements-frozen.txt

# Copy backend + agent code
COPY backend/ ./backend/
COPY orchestrator_agent/ ./orchestrator_agent/

# Copy the built frontend from stage 1
COPY --from=frontend-build /app/backend/static ./backend/static

# Expose port
EXPOSE 8080

# Run
CMD ["python", "-m", "uvicorn", "backend.server:app", "--host", "0.0.0.0", "--port", "8080"]
