# ── Azure OpenAI ──
AOAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
AOAI_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment>

# ── Fabric GraphQL API endpoints ──
# Format: https://api.fabric.microsoft.com/v1/workspaces/<workspace-id>/graphqlapis/<graphql-api-id>/graphql
FABRIC_SALES_GRAPHQL_URL=https://api.fabric.microsoft.com/v1/workspaces/<workspace-id>/graphqlapis/<sales-graphql-id>/graphql
FABRIC_CUSTOMER_GRAPHQL_URL=https://api.fabric.microsoft.com/v1/workspaces/<workspace-id>/graphqlapis/<customer-graphql-id>/graphql
FABRIC_PRODUCT_GRAPHQL_URL=https://api.fabric.microsoft.com/v1/workspaces/<workspace-id>/graphqlapis/<product-graphql-id>/graphql
