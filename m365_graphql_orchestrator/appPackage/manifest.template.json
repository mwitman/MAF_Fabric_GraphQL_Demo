{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.21/MicrosoftTeams.schema.json",
  "manifestVersion": "1.21",
  "version": "1.0.0",
  "id": "00000000-0000-0000-0000-000000000000",
  "developer": {
    "name": "Your Organization",
    "websiteUrl": "https://example.com",
    "privacyUrl": "https://privacy.microsoft.com",
    "termsOfUseUrl": "https://www.microsoft.com/servicesagreement"
  },
  "name": {
    "short": "GraphQL Agents Orchestrator",
    "full": "GraphQL Agents Orchestrator (Fabric GraphQL)"
  },
  "description": {
    "short": "Orchestrates Agent Framework sub-agents with Fabric GraphQL for sales, customers, and products",
    "full": "Orchestrates three Agent Framework sub-agents (Sales, Customer, Product) that use Fabric GraphQL APIs for data retrieval to answer business questions across orders, customers, addresses, products, categories, and more."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#00A651",
  "bots": [
    {
      "botId": "00000000-0000-0000-0000-000000000000",
      "scopes": [
        "personal",
        "team",
        "groupChat"
      ],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupChat"],
          "commands": [
            {
              "title": "What were the top 10 sales orders last quarter?",
              "description": "Query sales data from Fabric GraphQL"
            },
            {
              "title": "Show me details for customer Contoso Ltd",
              "description": "Look up customer information"
            },
            {
              "title": "Which products have the highest margin?",
              "description": "Analyze product profitability"
            }
          ]
        }
      ]
    }
  ],
  "copilotAgents": {
    "customEngineAgents": [
      {
        "type": "bot",
        "id": "00000000-0000-0000-0000-000000000000"
      }
    ]
  },
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "webApplicationInfo": {
    "id": "00000000-0000-0000-0000-000000000000",
    "resource": "api://botid-00000000-0000-0000-0000-000000000000"
  },
  "validDomains": [
    "your-app.azurewebsites.net",
    "token.botframework.com",
    "login.microsoftonline.com",
    "login.windows.net"
  ]
}
