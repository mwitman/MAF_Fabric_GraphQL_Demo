# ── Anonymous mode ──
# Set True for local emulator / dev tunnel testing without bot registration
USE_ANONYMOUS_MODE=False

# ── M365 Agents SDK — Azure Bot registration ──
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<your-bot-app-id>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<your-bot-client-secret>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<your-tenant-id>

# ── Fabric SSO/OBO — per-user Fabric access via Teams sign-in ──
# Name of the OAuth connection configured on the Azure Bot resource
# (Azure Bot → Settings → Configuration → OAuth Connection Settings)
FABRIC_ABS_OAUTH_CONNECTION_NAME=FabricOAuth

# ── Azure OpenAI ──
AOAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com
AOAI_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT_NAME=<your-deployment-name>
# NOTE: Do NOT set AZURE_OPENAI_API_VERSION — the MAF SDK default ("preview") is correct.

# ── Fabric GraphQL API endpoints ──
# All three can point to the same GraphQL API if the schema covers all domains,
# or separate APIs if you split sales/customer/product into different endpoints.
# Format: https://<workspace-guid>.z3e.graphql.fabric.microsoft.com/v1/workspaces/<workspace-id>/graphqlapis/<graphql-api-id>/graphql
FABRIC_SALES_GRAPHQL_URL=<your-fabric-graphql-url>
FABRIC_CUSTOMER_GRAPHQL_URL=<your-fabric-graphql-url>
FABRIC_PRODUCT_GRAPHQL_URL=<your-fabric-graphql-url>
